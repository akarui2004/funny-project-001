{
  "name": "backend-funny-project-001",
  "version": "1.0.0",
  "description": "This is just a project for fun",
  "main": "src/server.ts",
  "license": "MIT",
  "scripts": {
    "script": "ts-node -r dotenv/config -r tsconfig-paths/register",
    "db:config": "yarn script ./scripts/db/genConfig"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts,toml",
    "ignore": [
      "dist/**",
      "logs/**",
      "scripts/**"
    ],
    "exec": "ts-node -r dotenv/config -r tsconfig-paths/register src/server.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "deepmerge": "^4.3.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "toml": "^4.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3"
  }
}
